# =========================
# VISION CORE (CRÍTICO)
# =========================

# NÃO versionar caches internos
extracted/**/__pycache__/
extracted/**/*.pyc

# NÃO versionar arquivos compilados dentro das versões
versions/**/__pycache__/
versions/**/*.pyc

# NÃO versionar logs internos
extracted/**/logs/
extracted/**/tmp/

# NÃO versionar arquivos temporários
*.tmp
*.bak

# =========================
# OPCIONAL (se crescer muito)
# =========================

# Ignorar arquivos grandes desnecessários
# *.zip
